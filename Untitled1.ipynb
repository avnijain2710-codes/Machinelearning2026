   "source": [
    "%%writefile .gitignore\n",
    "# Virtual Environment\n",
    "venv/\n",
    ".venv/\n",
    "env/\n",
    "\n",
    "# Python cache\n",
    "__pycache__/\n",
    "*.py[cod]\n",
    "\n",
    "# Jupyter\n",
    ".ipynb_checkpoints/\n",
    "\n",
    "# VS Code\n",
    ".vscode/\n",
    "\n",
    "# Environment variables\n",
    ".env\n",
    "\n",
    "# Logs\n",
    "*.log\n",
    "\n",
    "# OS files\n",
    ".DS_Store\n",
    "Thumbs.db"
   ]
